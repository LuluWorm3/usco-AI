# dependencies
/node_modules
/.pnp
.pnp.js
.yarn/install-state.gz

# testing
/coverage

# Next.js
/.next/  # Correct, this will ignore the entire Next.js build output
/out/    # If you are using static export, this folder might be generated
/build   # This is also sometimes generated in production builds

# environment variables
.env     # Ignores the environment variable file
.env*.local  # Ignores environment-specific .env files
.env.*     # If you have multiple .env files like .env.production, .env.staging, etc.

/.vercel  # Correct, this will ignore local Vercel deployment config
.DS_Store # macOS specific, safe to keep

# TypeScript
*.tsbuildinfo  # TypeScript incremental compilation file
next-env.d.ts  # Next.js auto-generated TypeScript declaration

# misc
*.pem       # If you’re using any SSL certificates in development
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Ignore Logs
*.log

# Ignore IDE config files (optional)
.vscode/
.idea/

# Ignore lock files (optional)
package-lock.json
yarn.lock
src.md/
